import std::https;

fn hex_digit(u8 value) -> u8 {
    if (value >= u8(48)) {
        if (value <= u8(57)) {
            return value - u8(48);
        }
    }
    return value - u8(87);
}

fn decode_hex(string value, u8* output) -> bool {
    u64 count = string_length(value) / 2;
    u64 index = 0;
    while (index < count) {
        output[index] = (hex_digit(string_byte(value, index * 2)) << 4) |
            hex_digit(string_byte(value, index * 2 + 1));
        index = index + 1;
    }
    return true;
}

fn main() -> int {
    u8* certificate_pin = malloc(32);
    u8* rsa_modulus = malloc(256);
    decode_hex(
        "a7b5991507fde30924bc14aaf77a1b2ab70eeb67dcd7e51eb00c8562bc84e7cc",
        certificate_pin);
    decode_hex(
        "",
        rsa_modulus);

    std::https request;
    request.host = "localhost";
    request.path = "/";
    request.port = u16(9443);
    request.certificate_sha256 = certificate_pin;
    request.certificate_sha256_length = 32;
    request.rsa_modulus = rsa_modulus;
    request.rsa_modulus_length = 256;
    if (!request.get()) {
        print(request.error);
        return 1;
    }
    print(request.response);
    free(rsa_modulus);
    free(certificate_pin);
    return 42;
}
