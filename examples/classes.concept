class Simple {
    i32 value;
    string name;

    @complexity(25)
    fn increment() -> int {
        this.value = this.value + 1;
        return this.value;
    }

    fn increment_twice() -> int {
        this.increment();
        return this.increment();
    }

    fn label() -> string {
        return this.name;
    }
}

@complexity(50)
fn main() -> int {
    println("Hello World!");
    return 0;
}
