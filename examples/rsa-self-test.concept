import std::rsa;

fn hex_digit(u8 value) -> u8 {
    if (value >= u8(48)) {
        if (value <= u8(57)) {
            return value - u8(48);
        }
    }
    return value - u8(87);
}

fn decode_hex(string value, u8* output) -> bool {
    u64 count = string_length(value) / 2;
    u64 index = 0;
    while (index < count) {
        output[index] = (hex_digit(string_byte(value, index * 2)) << 4) |
            hex_digit(string_byte(value, index * 2 + 1));
        index = index + 1;
    }
    return true;
}

fn main() -> int {
    u8* modulus = malloc(256);
    u8* signature = malloc(256);
    u8* message_hash = malloc(32);
    decode_hex("", modulus);
    decode_hex("", signature);
    decode_hex("c3711e45140fab85d92254549204333433eca749cca5df3c2ff9703fe8ca9a36", message_hash);
    if (!std::rsa::verify_pss_sha256(
        modulus, 256, signature, 256, message_hash)) {
        return 1;
    }
    signature[0] = signature[0] ^ u8(1);
    if (std::rsa::verify_pss_sha256(
        modulus, 256, signature, 256, message_hash)) {
        return 2;
    }
    free(message_hash);
    free(signature);
    free(modulus);
    return 42;
}
